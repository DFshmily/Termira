{
  "name": "@termira/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Termira macOS desktop SSH client.",
  "author": "Termira",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "concurrently -k -n renderer,electron-ts,electron -c cyan,magenta,green \"npm:dev:renderer\" \"npm:dev:electron:watch\" \"npm:dev:electron:start\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron:watch": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron:start": "wait-on tcp:5173 dist-electron/main/index.js dist-electron/preload/index.js && electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "tsc -p tsconfig.json --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "icon:mac": "node scripts/generate-mac-icon.mjs",
    "pack:mac": "npm run icon:mac && ELECTRON_BUILDER_CACHE=../../.electron-builder-cache electron-builder --mac --dir",
    "dist:mac": "npm run icon:mac && ELECTRON_BUILDER_CACHE=../../.electron-builder-cache electron-builder --mac && node scripts/create-mac-dmg.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@termira/shared": "0.1.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "41.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wait-on": "^8.0.1"
  }
}
